{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "browser-remote",
  "description": "Review browser child webview — localhost dev servers only",
  "webviews": ["review-browser"],
  "remote": {
    "urls": [
      "http://localhost:*",
      "http://127.0.0.1:*",
      "https://localhost:*",
      "https://127.0.0.1:*"
    ]
  },
  "permissions": [
    "core:default",
    "allow-browser-host-message"
  ]
}
