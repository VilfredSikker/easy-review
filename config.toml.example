# er — example configuration
#
# Place this file at:
#   Per-repo:  .er-config.toml       (highest priority)
#   Global:    ~/.config/er/config.toml
#
# Per-repo overrides global. Merging is deep: individual fields within
# sections override independently, so you only need to specify what you
# want to change.

# ── Views ──────────────────────────────────────────────────────────────
# Toggle which diff views are available (keys 1-6).
[features]
view_branch   = true   # Branch diff (1)
view_unstaged = true   # Unstaged changes (2)
view_staged   = true   # Staged changes (3)
view_history  = true   # Commit history (4)
view_conflicts = true  # Merge conflicts (5)
view_hidden   = true   # Hidden/ignored files (6)

# ── Display ────────────────────────────────────────────────────────────
[display]
theme        = "graphite"  # graphite | slate | midnight | ember (dark) · paper | daylight (light) · contrast-dark | contrast-light (a11y)
line_numbers = true
wrap_lines   = false
split_diff   = false
tab_width    = 4
auto_context_threshold = 50   # Auto-expand full context for files with <= N diff lines (0 to disable)

# ── Key Hints ──────────────────────────────────────────────────────────
# Toggle hint groups shown in the bottom status bar.
[hints]
navigation = true    # j/k, n/N, Space, /
comments   = true    # r, d
staging    = true    # s, c commit
verbose    = false   # Show all keybindings (more detail)

# ── Agent ──────────────────────────────────────────────────────────────
# The AI agent used for review commands. {prompt} is replaced with user input.
[agent]
command = "claude"
args    = ["--print", "--output-format", "stream-json", "-p", "{prompt}"]

# Optional AI Hub presets for choosing provider/model at runtime.
# If omitted, AI Hub falls back to the single [agent] config above.
[ai_hub]
default_provider = "claude"
default_model = "sonnet-5"
# Optional global effort/reasoning override; omit or use Auto in the UI for provider default.
# default_effort = "high"

[ai_hub.providers.claude]
label = "Claude"
command = "claude"
args = ["--print", "-p", "{prompt}"]

[[ai_hub.providers.claude.models]]
id = "fable-5"
label = "Fable 5"
description = "Frontier reasoning · maximum depth"
args = ["--model", "claude-fable-5"]
effort_levels = ["low", "medium", "high", "xhigh", "max"]
cost_per_1k_in = 0.003
cost_per_1k_out = 0.015
avg_latency_ms = 12000

[[ai_hub.providers.claude.models]]
id = "sonnet-5"
label = "Sonnet 5"
description = "Best speed + intelligence · 1M context"
args = ["--model", "claude-sonnet-5"]
effort_levels = ["low", "medium", "high", "xhigh", "max"]
cost_per_1k_in = 0.002
cost_per_1k_out = 0.010
avg_latency_ms = 12000

[[ai_hub.providers.claude.models]]
id = "opus-4.8"
label = "Opus 4.8"
description = "Latest frontier · 1M context"
args = ["--model", "claude-opus-4-8"]
effort_levels = ["low", "medium", "high", "xhigh", "max"]
cost_per_1k_in = 0.005
cost_per_1k_out = 0.025
avg_latency_ms = 24000

[[ai_hub.providers.claude.models]]
id = "haiku-4.5"
label = "Haiku 4.5"
description = "Fast & cheap · good for noise"
args = ["--model", "claude-haiku-4-5-20251001"]
effort_levels = []
cost_per_1k_in = 0.001
cost_per_1k_out = 0.005
avg_latency_ms = 5000

[ai_hub.providers.codex]
label = "Codex"
command = "codex"
args = ["exec", "--ignore-user-config", "--skip-git-repo-check", "--sandbox", "workspace-write", "{prompt}"]

[[ai_hub.providers.codex.models]]
id = "gpt-5.4"
label = "GPT-5.4"
description = "Strong general · lower cost"
args = ["--model", "gpt-5.4"]
effort_levels = ["low", "medium", "high", "xhigh"]
cost_per_1k_in = 0.0025
cost_per_1k_out = 0.015
avg_latency_ms = 14000

[[ai_hub.providers.codex.models]]
id = "gpt-5.5"
label = "GPT-5.5"
description = "Best-in-class general"
args = ["--model", "gpt-5.5"]
effort_levels = ["low", "medium", "high", "xhigh"]
cost_per_1k_in = 0.005
cost_per_1k_out = 0.030
avg_latency_ms = 18000

[[ai_hub.providers.codex.models]]
id = "gpt-5.6-sol"
label = "GPT-5.6 Sol"
description = "Flagship reasoning · detail + polish"
args = ["--model", "gpt-5.6-sol"]
effort_levels = ["low", "medium", "high", "xhigh", "max"]
cost_per_1k_in = 0.005
cost_per_1k_out = 0.030
avg_latency_ms = 20000

[[ai_hub.providers.codex.models]]
id = "gpt-5.6-terra"
label = "GPT-5.6 Terra"
description = "Strong everyday coding + tool use"
args = ["--model", "gpt-5.6-terra"]
effort_levels = ["low", "medium", "high", "xhigh", "max"]
cost_per_1k_in = 0.0025
cost_per_1k_out = 0.015
avg_latency_ms = 14000

[[ai_hub.providers.codex.models]]
id = "gpt-5.6-luna"
label = "GPT-5.6 Luna"
description = "Fast, efficient repeatable work"
args = ["--model", "gpt-5.6-luna"]
effort_levels = ["low", "medium", "high", "xhigh", "max"]
cost_per_1k_in = 0.001
cost_per_1k_out = 0.005
avg_latency_ms = 8000

[[ai_hub.providers.codex.models]]
id = "gpt-5.4-mini"
label = "GPT-5.4 Mini"
description = "Fast, efficient coding"
args = ["--model", "gpt-5.4-mini"]
effort_levels = ["low", "medium", "high", "xhigh"]

[[ai_hub.providers.codex.models]]
id = "gpt-5.3-codex-spark"
label = "GPT-5.3 Codex Spark"
description = "Fast coding specialist"
args = ["--model", "gpt-5.3-codex-spark"]
effort_levels = ["low", "medium", "high", "xhigh"]

[ai_hub.providers.cursor]
label = "Cursor"
command = "agent"
args = [
    "--print",
    "--trust",
    "--force",
    "--output-format",
    "stream-json",
    "-p",
    "{prompt}",
]

[[ai_hub.providers.cursor.models]]
id = "grok-4.5"
label = "Grok 4.5"
description = "Long-running agentic · coding + knowledge work"
args = ["--model", "grok-4.5"]
cost_per_1k_in = 0.002
cost_per_1k_out = 0.006
avg_latency_ms = 18000

[[ai_hub.providers.cursor.models]]
id = "composer-2.5"
label = "Composer 2.5"
description = "Agentic coding · frontier quality at low cost"
args = ["--model", "composer-2.5"]
cost_per_1k_in = 0.0005
cost_per_1k_out = 0.0025
avg_latency_ms = 12000

# ── Summary ────────────────────────────────────────────────────────────
# Diff summary / changelog generation (AI hub).
[summary]
# command    = "claude"                             # Defaults to agent.command
# args       = ["--print", "-p", "{diff}"]          # {diff} is replaced with the raw diff
push_to_pr = false                                  # Auto-push summary to GitHub PR body

# ── Watched Files ──────────────────────────────────────────────────────
# Glob patterns for git-ignored paths to monitor (e.g. AI sync folders).
# Visible via W key. Patterns are matched against the repo root.
[watched]
paths     = []            # e.g. [".work/**/*", ".er/**/*"]
diff_mode = "content"     # "content" (show file contents) or "snapshot" (diff against saved baseline)

# ── Commands ───────────────────────────────────────────────────────────
# Shell commands for the hub actions. Run via `sh -c`.
# Placeholders: {base} (base branch), {branch} (current branch),
#               {repo} (repo root), {output} (default output path).
# Leave unset to disable the action in the UI.
[commands]
# summary   = "claude --print -p 'Summarize this diff: {base}...{branch}'"
# test      = "cargo test"
# lint      = "cargo clippy"
# typecheck = "cargo check"
# security  = "cargo audit"
